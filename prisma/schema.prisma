generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  emailVerified       Boolean              @default(false)
  image               String?
  phone               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isActive            Boolean              @default(false)
  banExpires          DateTime?
  banReason           String?
  banned              Boolean?             @default(false)
  customerMetadata    String?
  role                String?
  businessId          String?
  accounts            Account[]
  addresses           Address[]
  ownedBusinesses     Business[]           @relation("BusinessOwner")
  conversations       Conversation[]       @relation("CustomerConversations")
  createdEmployees    EmployeeProfile[]    @relation("CreatedByUser")
  employeeProfiles    EmployeeProfile[]
  invitations         Invitation[]
  members             Member[]
  orders              Order[]
  passwordResetTokens PasswordResetToken[]
  push_subscriptions  PushSubscription[]
  sessions            Session[]

  @@map("users")
}

model Session {
  id                   String   @id @default(cuid())
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  activeOrganizationId String?
  impersonatedBy       String?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  type                  String    @default("credential")
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Business {
  id                    String               @id @default(cuid())
  email                 String               @unique
  password              String
  name                  String
  description           String?
  phone                 String
  address               String
  avatar                String?
  banner                String?
  isOpen                Boolean              @default(true)
  openingHours          String?
  deliveryFee           Float                @default(0)
  minimumOrder          Float                @default(0)
  deliveryTime          Int                  @default(30)
  acceptsDelivery       Boolean              @default(true)
  acceptsPickup         Boolean              @default(true)
  acceptsDineIn         Boolean              @default(true)
  isActive              Boolean              @default(false)
  subscriptionExpiresAt DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  ownerId               String?
  slug                  String?
  additionals           BusinessAdditional[]
  owner                 User?                @relation("BusinessOwner", fields: [ownerId], references: [id])
  categories            Category[]
  conversations         Conversation[]       @relation("BusinessConversations")
  employeeProfiles      EmployeeProfile[]
  orders                Order[]
  payments              Payment[]
  products              Product[]
  promotions            Promotion[]
  pushSubscriptions     PushSubscription[]
  roles                 Role[]
  subscription          Subscription?
  tables                Table[]

  @@map("businesses")
}

model Category {
  id            String     @id @default(cuid())
  name          String
  description   String?
  isActive      Boolean    @default(true)
  order         Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  parentId      String?
  businessId    String
  business      Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subcategories Category[] @relation("CategoryHierarchy")
  products      Product[]

  @@unique([businessId, name])
  @@map("categories")
}

model Product {
  id          String              @id @default(cuid())
  categoryId  String
  name        String
  description String?
  price       Float
  image       String?
  isAvailable Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  businessId  String
  orderItems  OrderItem[]
  additionals ProductAdditional[]
  options     ProductOption[]
  business    Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category    Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@map("products")
}

model ProductOption {
  id          String              @id @default(cuid())
  productId   String
  name        String
  description String?
  price       Float               @default(0)
  isRequired  Boolean             @default(false)
  maxOptions  Int                 @default(1)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  options     ProductOptionItem[]
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_options")
}

model ProductOptionItem {
  id              String        @id @default(cuid())
  productOptionId String
  name            String
  price           Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  productOption   ProductOption @relation(fields: [productOptionId], references: [id], onDelete: Cascade)

  @@map("product_option_items")
}

model BusinessAdditional {
  id          String                   @id @default(cuid())
  businessId  String
  name        String
  description String?
  price       Float                    @default(0)
  isRequired  Boolean                  @default(false)
  maxOptions  Int                      @default(1)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  items       BusinessAdditionalItem[]
  business    Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    ProductAdditional[]

  @@map("business_additionals")
}

model BusinessAdditionalItem {
  id           String             @id @default(cuid())
  additionalId String
  name         String
  price        Float              @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  additional   BusinessAdditional @relation(fields: [additionalId], references: [id], onDelete: Cascade)

  @@map("business_additional_items")
}

model ProductAdditional {
  id           String             @id @default(cuid())
  productId    String
  additionalId String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  additional   BusinessAdditional @relation(fields: [additionalId], references: [id], onDelete: Cascade)
  product      Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, additionalId])
  @@map("product_additionals")
}

model Table {
  id         String   @id @default(cuid())
  number     String
  qrCode     String   @unique
  isOccupied Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isReserved Boolean  @default(false)
  businessId String
  orders     Order[]
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("tables")
}

model Order {
  id              String                @id @default(cuid())
  userId          String?
  tableId         String?
  orderNumber     String                @unique
  type            OrderType
  status          OrderStatus           @default(PENDING)
  subtotal        Float
  deliveryFee     Float                 @default(0)
  discount        Float                 @default(0)
  total           Float
  deliveryAddress String?
  customerName    String
  customerPhone   String
  customerEmail   String?
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus         @default(PENDING)
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  businessId      String
  eventIngestions OrderEventIngestion[]
  history         OrderHistory[]
  items           OrderItem[]
  business        Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  table           Table?                @relation(fields: [tableId], references: [id])
  user            User?                 @relation(fields: [userId], references: [id])
  payments        Payment[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  options   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Promotion {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        PromotionType
  value       Float
  minOrder    Float?
  maxDiscount Float?
  code        String?
  validFrom   DateTime
  validTo     DateTime
  isActive    Boolean       @default(true)
  usageLimit  Int?
  usageCount  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  businessId  String
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("promotions")
}

model Payment {
  id                String        @id @default(cuid())
  preferenceId      String        @unique
  externalReference String
  status            PaymentStatus @default(PENDING)
  amount            Float
  type              String
  orderId           String?
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  businessId        String
  business          Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order             Order?        @relation(fields: [orderId], references: [id])

  @@index([externalReference])
  @@index([orderId])
  @@map("payments")
}

model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  externalId String
  eventType  String
  status     String?
  signature  String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@unique([provider, externalId, eventType])
  @@index([provider, externalId])
  @@map("webhook_events")
}

model Subscription {
  id                   String             @id @default(cuid())
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  maxOrders            Int
  maxProducts          Int
  maxTables            Int
  maxUsers             Int
  hasAdvancedAnalytics Boolean            @default(false)
  hasPrioritySupport   Boolean            @default(false)
  hasCustomBranding    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  /// Referência genérica usada pelo plugin (userId ou businessId)
  referenceId          String?
  periodEnd            DateTime?
  periodStart          DateTime?
  plan                 String
  seats                Int?
  trialEnd             DateTime?
  trialStart           DateTime?
  businessId           String             @unique
  business             Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  usage                UsageStats[]

  @@map("subscriptions")
}

model UsageStats {
  id             String       @id @default(cuid())
  subscriptionId String
  year           Int
  month          Int
  ordersCount    Int          @default(0)
  productsCount  Int          @default(0)
  tablesCount    Int          @default(0)
  usersCount     Int          @default(0)
  resetAt        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, year, month])
  @@map("usage_stats")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Image {
  id           String   @id
  filename     String
  originalName String
  url          String
  thumbnailUrl String?
  size         Int
  type         String
  entityId     String
  category     String?
  hash         String
  metadata     Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([entityId, type])
  @@index([hash])
  @@map("images")
}

model Role {
  id          String            @id @default(cuid())
  name        String
  description String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  businessId  String
  employees   EmployeeProfile[]
  permissions Permission[]
  business    Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@map("roles")
}

model Permission {
  id         String   @id @default(cuid())
  roleId     String
  resource   String
  action     String
  conditions Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("permissions")
}

model EmployeeProfile {
  id          String    @id @default(cuid())
  userId      String
  roleId      String
  isActive    Boolean   @default(true)
  startDate   DateTime  @default(now())
  endDate     DateTime?
  salary      Float?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("CreatedByUser", fields: [createdById], references: [id])
  role        Role      @relation(fields: [roleId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@map("employee_profiles")
}

model Organization {
  id                     String       @id
  name                   String
  slug                   String?      @unique
  logo                   String?
  createdAt              DateTime
  metadata               String?
  cuisine                String?
  deliveryFee            Int?
  minimumOrder           Int?
  deliveryTime           Int?
  acceptsDelivery        Boolean?
  acceptsPickup          Boolean?
  acceptsDineIn          Boolean?
  isOpen                 Boolean?
  isActive               Boolean?
  phone                  String?
  address                String?
  description            String?
  subscriptionPlan       String?
  mercadoPagoAccessToken String?
  mercadoPagoPublicKey   String?
  mercadoPagoConfigured  Boolean?
  invitations            Invitation[]
  members                Member[]

  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  userId         String
  role           String
  createdAt      DateTime
  salary         Int?
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean?
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  inviteMessage  String?
  departmentId   String?
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model Conversation {
  id         String        @id @default(cuid())
  customerId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  businessId String
  messages   ChatMessage[]
  business   Business      @relation("BusinessConversations", fields: [businessId], references: [id], onDelete: Cascade)
  customer   User          @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, businessId])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  content        String
  senderType     SenderType
  senderId       String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

/// Raw ingestion of order-related events coming from any internal source (polling, adapters, etc.).
/// Acts as an idempotency layer (unique eventId) and staging for processing pipeline.
model OrderEventIngestion {
  id             String         @id @default(cuid())
  eventId        String         @unique
  orderNumber    String?
  orderId        String?
  type           String
  payload        Json
  processedAt    DateTime?
  attempts       Int            @default(0)
  createdAt      DateTime       @default(now())
  order          Order?         @relation(fields: [orderId], references: [id])
  historyEntries OrderHistory[]

  @@index([orderId])
  @@index([orderNumber])
  @@map("order_event_ingestion")
}

/// Historical timeline of state transitions applied to an Order after normalization.
/// Facilitates audit, debugging and replay of order lifecycle.
model OrderHistory {
  id               String               @id @default(cuid())
  orderId          String
  eventIngestionId String?
  fromStatus       OrderStatus?
  toStatus         OrderStatus?
  transitionType   String
  reason           String?
  metadata         Json?
  occurredAt       DateTime             @default(now())
  createdAt        DateTime             @default(now())
  ingestion        OrderEventIngestion? @relation(fields: [eventIngestionId], references: [id])
  order            Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([eventIngestionId])
  @@map("order_history")
}

/// Armazena subscriptions de Push Notifications (Web Push API)
model PushSubscription {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String
  endpoint   String
  p256dh     String
  auth       String
  userId     String?
  userAgent  String?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  lastUsedAt DateTime? @db.Timestamptz(6)
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User?     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([businessId, endpoint], name: "unique_endpoint_per_business", map: "unique_endpoint_per_business")
  @@index([businessId], map: "idx_push_subscriptions_business")
  @@index([userId], map: "idx_push_subscriptions_user")
  @@map("push_subscriptions")
}

enum OrderType {
  DELIVERY
  PICKUP
  DINE_IN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  MONEY
  CREDIT_CARD
  DEBIT_CARD
  PIX
  STRIPE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  INCOMPLETE
  TRIALING
}

enum SenderType {
  CUSTOMER
  BUSINESS
}

model ClientSession {
  deviceId      String    @id
  orderId       String
  businessSlug  String
  tableNumber   String?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  
  @@index([orderId])
  @@index([businessSlug])
  @@index([expiresAt])
}
