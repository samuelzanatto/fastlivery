generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  emailVerified    Boolean           @default(false)
  image            String?
  phone            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  stripeCustomerId String?
  isActive         Boolean           @default(false)
  banExpires       DateTime?
  banReason        String?
  banned           Boolean?          @default(false)
  customerMetadata String?
  businessId     String?
  role             String?
  accounts         Account[]
  addresses        Address[]
  conversations    Conversation[]    @relation("CustomerConversations")
  createdEmployees EmployeeProfile[] @relation("CreatedByUser")
  employeeProfiles EmployeeProfile[]
  invitations      Invitation[]
  members          Member[]
  orders           Order[]
  ownedBusinesses Business[]      @relation("BusinessOwner")
  sessions         Session[]

  // Novos relacionamentos B2B
  ownedCompanies       Company[]             @relation("CompanyOwner")
  createdPartnerships  Partnership[]         
  partnershipRequests  PartnershipRequest[]  
  partnershipResponses PartnershipRequest[]  @relation("PartnershipRequestResponses")
  supplierReviews      SupplierReview[]      
  marketplaceFavorites MarketplaceFavorite[] 
  marketplaceActivities MarketplaceActivity[]

  @@map("users")
}

model Session {
  id                   String   @id @default(cuid())
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  activeOrganizationId String?
  impersonatedBy       String?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  type                  String    @default("credential")
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Business {
  id                     String                 @id @default(cuid())
  email                  String                 @unique
  password               String
  name                   String
  description            String?
  phone                  String
  address                String
  avatar                 String?
  banner                 String?
  isOpen                 Boolean                @default(true)
  openingHours           String?
  deliveryFee            Float                  @default(0)
  minimumOrder           Float                  @default(0)
  deliveryTime           Int                    @default(30)
  acceptsDelivery        Boolean                @default(true)
  acceptsPickup          Boolean                @default(true)
  acceptsDineIn          Boolean                @default(true)
  isActive               Boolean                @default(false)
  subscriptionExpiresAt  DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  ownerId                String?
  slug                   String?
  mercadoPagoAccessToken String?
  mercadoPagoConfigured  Boolean                @default(false)
  mercadoPagoPublicKey   String?
  categories             Category[]
  conversations          Conversation[]         @relation("BusinessConversations")
  employeeProfiles       EmployeeProfile[]
  orders                 Order[]
  payments               Payment[]
  products               Product[]
  promotions             Promotion[]
  additionals            BusinessAdditional[]
  owner                  User?                  @relation("BusinessOwner", fields: [ownerId], references: [id])
  roles                  Role[]
  subscription           Subscription?
  tables                 Table[]

  @@map("businesses")
}

model Category {
  id           String     @id @default(cuid())
  businessId   String
  name         String
  description  String?
  isActive     Boolean    @default(true)
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  parentId     String?
  parent       Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subcategories Category[] @relation("CategoryHierarchy")
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([businessId, name])
  @@map("categories")
}

model Product {
  id           String              @id @default(cuid())
  businessId   String
  categoryId   String
  name         String
  description  String?
  price        Float
  image        String?
  isAvailable  Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  orderItems   OrderItem[]
  additionals  ProductAdditional[]
  options      ProductOption[]
  category     Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@map("products")
}

model ProductOption {
  id          String              @id @default(cuid())
  productId   String
  name        String
  description String?
  price       Float               @default(0)
  isRequired  Boolean             @default(false)
  maxOptions  Int                 @default(1)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  options     ProductOptionItem[]
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_options")
}

model ProductOptionItem {
  id              String        @id @default(cuid())
  productOptionId String
  name            String
  price           Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  productOption   ProductOption @relation(fields: [productOptionId], references: [id], onDelete: Cascade)

  @@map("product_option_items")
}

model BusinessAdditional {
  id           String                     @id @default(cuid())
  businessId   String
  name         String
  description  String?
  price        Float                      @default(0)
  isRequired   Boolean                    @default(false)
  maxOptions   Int                        @default(1)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  products     ProductAdditional[]
  items        BusinessAdditionalItem[]
  business     Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_additionals")
}

model BusinessAdditionalItem {
  id           String               @id @default(cuid())
  additionalId String
  name         String
  price        Float                @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  additional   BusinessAdditional @relation(fields: [additionalId], references: [id], onDelete: Cascade)

  @@map("business_additional_items")
}

model ProductAdditional {
  id           String               @id @default(cuid())
  productId    String
  additionalId String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  additional   BusinessAdditional @relation(fields: [additionalId], references: [id], onDelete: Cascade)
  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, additionalId])
  @@map("product_additionals")
}

model Table {
  id           String     @id @default(cuid())
  businessId   String
  number       String
  qrCode       String     @unique
  isOccupied   Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  isReserved   Boolean    @default(false)
  orders       Order[]
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("tables")
}

model Order {
  id              String         @id @default(cuid())
  userId          String?
  businessId      String
  tableId         String?
  orderNumber     String         @unique
  type            OrderType
  status          OrderStatus    @default(PENDING)
  subtotal        Float
  deliveryFee     Float          @default(0)
  discount        Float          @default(0)
  total           Float
  deliveryAddress String?
  customerName    String
  customerPhone   String
  customerEmail   String?
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus  @default(PENDING)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  stripeSessionId String?
  items           OrderItem[]
  business        Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  table           Table?         @relation(fields: [tableId], references: [id])
  user            User?          @relation(fields: [userId], references: [id])
  payments        Payment[]
  eventIngestions OrderEventIngestion[]
  history         OrderHistory[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  options   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Promotion {
  id           String        @id @default(cuid())
  businessId   String
  name         String
  description  String?
  type         PromotionType
  value        Float
  minOrder     Float?
  maxDiscount  Float?
  code         String?
  validFrom    DateTime
  validTo      DateTime
  isActive     Boolean       @default(true)
  usageLimit   Int?
  usageCount   Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("promotions")
}

model Payment {
  id                String        @id @default(cuid())
  preferenceId      String        @unique
  externalReference String
  status            PaymentStatus @default(PENDING)
  amount            Float
  type              String
  businessId        String
  orderId           String?
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  stripePaymentId   String?
  stripeSessionId   String?
  order             Order?        @relation(fields: [orderId], references: [id])
  business          Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("payments")
  @@index([externalReference])
  @@index([orderId])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  externalId String
  eventType  String
  status     String?
  signature  String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@unique([provider, externalId, eventType])
  @@index([provider, externalId])
  @@map("webhook_events")
}

model Subscription {
  id                   String             @id @default(cuid())
  businessId           String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  maxOrders            Int
  maxProducts          Int
  maxTables            Int
  maxUsers             Int
  hasAdvancedAnalytics Boolean            @default(false)
  hasPrioritySupport   Boolean            @default(false)
  hasCustomBranding    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  /// Referência genérica usada pelo plugin (userId ou businessId)
  referenceId          String?
  periodEnd            DateTime?
  periodStart          DateTime?
  plan                 String
  seats                Int?
  trialEnd             DateTime?
  trialStart           DateTime?
  business             Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  usage                UsageStats[]

  @@map("subscriptions")
}

model UsageStats {
  id             String       @id @default(cuid())
  subscriptionId String
  year           Int
  month          Int
  ordersCount    Int          @default(0)
  productsCount  Int          @default(0)
  tablesCount    Int          @default(0)
  usersCount     Int          @default(0)
  resetAt        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, year, month])
  @@map("usage_stats")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Image {
  id           String   @id
  filename     String
  originalName String
  url          String
  thumbnailUrl String?
  size         Int
  type         String
  entityId     String
  category     String?
  hash         String
  metadata     Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([entityId, type])
  @@index([hash])
  @@map("images")
}

model StripeProduct {
  id          String        @id
  name        String
  description String?
  active      Boolean       @default(true)
  metadata    Json          @default("{}")
  created     DateTime
  updated     DateTime      @updatedAt
  prices      StripePrice[]

  @@map("stripe_products")
}

model StripePrice {
  id         String        @id
  productId  String
  active     Boolean       @default(true)
  currency   String
  unitAmount Int?
  recurring  Json?
  type       String
  metadata   Json          @default("{}")
  created    DateTime
  updated    DateTime      @updatedAt
  product    StripeProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stripe_prices")
}

model Role {
  id           String            @id @default(cuid())
  businessId   String
  name         String
  description  String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  employees    EmployeeProfile[]
  permissions  Permission[]
  business     Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@map("roles")
}

model Permission {
  id         String   @id @default(cuid())
  roleId     String
  resource   String
  action     String
  conditions Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("permissions")
}

model EmployeeProfile {
  id           String     @id @default(cuid())
  userId       String
  businessId   String
  roleId       String
  isActive     Boolean    @default(true)
  startDate    DateTime   @default(now())
  endDate      DateTime?
  salary       Float?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdById  String
  createdBy    User       @relation("CreatedByUser", fields: [createdById], references: [id])
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id])
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@map("employee_profiles")
}

model Organization {
  id                     String       @id
  name                   String
  slug                   String?      @unique
  logo                   String?
  createdAt              DateTime
  metadata               String?
  cuisine                String?
  deliveryFee            Int?
  minimumOrder           Int?
  deliveryTime           Int?
  acceptsDelivery        Boolean?
  acceptsPickup          Boolean?
  acceptsDineIn          Boolean?
  isOpen                 Boolean?
  isActive               Boolean?
  phone                  String?
  address                String?
  description            String?
  subscriptionPlan       String?
  mercadoPagoAccessToken String?
  mercadoPagoPublicKey   String?
  mercadoPagoConfigured  Boolean?
  invitations            Invitation[]
  members                Member[]

  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  userId         String
  role           String
  createdAt      DateTime
  salary         Int?
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean?
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  inviteMessage  String?
  departmentId   String?
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model Conversation {
  id           String        @id @default(cuid())
  customerId   String
  businessId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]
  customer     User          @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: Cascade)
  business     Business    @relation("BusinessConversations", fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([customerId, businessId])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  content        String
  senderType     SenderType
  senderId       String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// =============================================
// Internal Order Event Sourcing / Ingestion
// =============================================

/// Raw ingestion of order-related events coming from any internal source (polling, adapters, etc.).
/// Acts as an idempotency layer (unique eventId) and staging for processing pipeline.
model OrderEventIngestion {
  id             String    @id @default(cuid())
  eventId        String    // provider or internal unique identifier for the event
  orderNumber    String?   // used to link to Order via orderNumber when internal id not known yet
  orderId        String?   // direct relation once resolved
  type           String    // e.g. ORDER_CREATED, ORDER_UPDATED, STATUS_CHANGED
  payload        Json      // raw payload for replay/debug
  processedAt    DateTime? // null until successfully applied to domain state
  attempts       Int       @default(0)
  createdAt      DateTime  @default(now())

  order          Order?    @relation(fields: [orderId], references: [id])
  historyEntries OrderHistory[]

  @@unique([eventId])
  @@index([orderId])
  @@index([orderNumber])
  @@map("order_event_ingestion")
}

/// Historical timeline of state transitions applied to an Order after normalization.
/// Facilitates audit, debugging and replay of order lifecycle.
model OrderHistory {
  id                String      @id @default(cuid())
  orderId           String
  eventIngestionId  String?     // optional link back to raw ingestion row
  fromStatus        OrderStatus?
  toStatus          OrderStatus?
  transitionType    String      // semantic label, e.g. CREATED, CONFIRMED, CANCELLED
  reason            String?     // optional reason / metadata (e.g. cancellation cause)
  metadata          Json?       // extended structured data (diffs, timing, etc.)
  occurredAt        DateTime    @default(now())
  createdAt         DateTime    @default(now())

  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ingestion         OrderEventIngestion? @relation(fields: [eventIngestionId], references: [id])

  @@index([orderId])
  @@index([eventIngestionId])
  @@map("order_history")
}

enum OrderType {
  DELIVERY
  PICKUP
  DINE_IN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  MONEY
  CREDIT_CARD
  DEBIT_CARD
  PIX
  STRIPE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  INCOMPLETE
  TRIALING
}


enum SenderType {
  CUSTOMER
  BUSINESS
}

// ======================================
// B2B MARKETPLACE ENUMS
// ======================================

enum CompanyType {
  BUSINESS  // Empresas de delivery
  SUPPLIER          // Fornecedores do marketplace B2B
}

enum StripeConnectStatus {
  NOT_CONNECTED     // Ainda não iniciou o processo
  PENDING           // Onboarding iniciado mas não completo
  CONNECTED         // Conta conectada com sucesso
  RESTRICTED        // Conta com restrições
  REJECTED          // Rejeitada pelo Stripe
}

enum SupplierCategory {
  FOOD_INGREDIENTS  // Ingredientes alimentícios
  PACKAGING        // Embalagens
  EQUIPMENT        // Equipamentos
  SERVICES         // Serviços diversos
  MARKETING        // Marketing e publicidade
  LOGISTICS        // Logística e transporte
  TECHNOLOGY       // Tecnologia e software
  CONSULTING       // Consultoria
  OTHER           // Outros
}

enum PartnershipStatus {
  PENDING         // Pendente aprovação
  ACTIVE          // Parceria ativa
  SUSPENDED       // Temporariamente suspensa
  TERMINATED      // Encerrada
}

enum PartnershipRequestStatus {
  PENDING         // Aguardando resposta
  APPROVED        // Aprovada (vira Partnership)
  REJECTED        // Rejeitada
  CANCELLED       // Cancelada pelo solicitante
}

// ======================================
// B2B MARKETPLACE MODELS
// ======================================

// Company model
// Suporta tanto empresas de delivery quanto fornecedores
model Company {
  id                     String                 @id @default(cuid())
  type                   CompanyType            @default(BUSINESS)
  email                  String                 @unique
  password               String
  name                   String
  slug                   String?                @unique
  description            String?
  phone                  String?
  address                String?
  city                   String?
  state                  String?
  country                String?                @default("BR")
  zipCode                String?
  website                String?
  logo                   String?                // antes era "avatar"
  banner                 String?
  isActive               Boolean                @default(false)
  isVerified             Boolean                @default(false)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  ownerId                String?

  // Campos específicos para empresas de delivery (compatibilidade)
  isOpen                 Boolean?               @default(true)
  openingHours           String?
  deliveryFee            Float?                 @default(0)
  minimumOrder           Float?                 @default(0)
  deliveryTime           Int?                   @default(30)
  acceptsDelivery        Boolean?               @default(true)
  acceptsPickup          Boolean?               @default(true)
  acceptsDineIn          Boolean?               @default(true)
  subscriptionExpiresAt  DateTime?
  mercadoPagoAccessToken String?
  mercadoPagoConfigured  Boolean?               @default(false)
  mercadoPagoPublicKey   String?

  // Stripe Connect fields
  stripeConnectAccountId    String?                // ID da conta conectada no Stripe
  stripeConnectStatus       StripeConnectStatus?   @default(NOT_CONNECTED)
  stripeConnectOnboardedAt  DateTime?              // Data quando completou o onboarding
  stripeConnectChargesEnabled Boolean?             @default(false)
  stripeConnectPayoutsEnabled Boolean?             @default(false)
  platformCommissionRate    Float?                 @default(5.0) // % de comissão da plataforma

  // Relacionamentos
  owner                  User?                  @relation("CompanyOwner", fields: [ownerId], references: [id])
  supplier               Supplier?              // Uma company pode ser um supplier
  
  // Novos relacionamentos B2B
  partnershipRequests    PartnershipRequest[]   @relation("CompanyPartnershipRequests")
  partnerships           Partnership[]          @relation("CompanyPartnerships")
  supplierReviews        SupplierReview[]       @relation("CompanySupplierReviews")
  marketplaceFavorites   MarketplaceFavorite[]  @relation("CompanyFavorites")
  marketplaceActivities  MarketplaceActivity[]  @relation("CompanyActivities")

  @@map("companies")
}

// Supplier model - Fornecedores no marketplace B2B
model Supplier {
  id                   String             @id @default(cuid())
  companyId            String             @unique
  category             SupplierCategory
  subCategory          String?
  businessModel        String?            // B2B, B2C, Both
  yearsInBusiness      Int?
  employeeCount        String?            // "1-10", "11-50", "51-200", "200+"
  certifications       Json               @default("[]")
  serviceAreas         Json               @default("[]") // ["SP", "RJ", "MG"] ou ["Nacional"]
  minOrderValue        Float?
  maxOrderValue        Float?
  paymentTerms         String?
  deliveryMethods      Json               @default("[]")
  averageDeliveryTime  Int?               // em dias
  responseTime         Int                @default(24) // horas para responder
  isActive             Boolean            @default(true)
  isFeatured           Boolean            @default(false)
  rating               Float              @default(0)
  totalReviews         Int                @default(0)
  totalOrders          Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Stripe Connect fields (herda da Company)
  stripeConnectAccountId    String?        @unique  // ID da conta conectada no Stripe

  // Relacionamentos
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  services             SupplierService[]
  partnershipRequests  PartnershipRequest[] @relation("SupplierPartnershipRequests")
  partnerships         Partnership[]      @relation("SupplierPartnerships")
  reviews              SupplierReview[]   @relation("SupplierReviews")
  favorites            MarketplaceFavorite[] @relation("SupplierFavorites")
  activities           MarketplaceActivity[] @relation("SupplierActivities")
  
  // Stripe Connect relationships
  stripeTransactions   StripeConnectTransaction[]
  stripeTransfers      StripeConnectTransfer[]
  
  // Subscription relationship
  subscription         SupplierSubscription?

  @@map("suppliers")
}

// SupplierService model - Produtos/serviços oferecidos
model SupplierService {
  id           String   @id @default(cuid())
  supplierId   String
  name         String
  description  String?
  category     String
  subCategory  String?
  unitType     String   // "kg", "unidade", "litro", "hora", "projeto"
  minQuantity  Float?
  maxQuantity  Float?
  pricePerUnit Float?
  priceType    String   @default("fixed") // "fixed", "negotiable", "quote"
  images       Json     @default("[]")
  specifications Json   @default("{}")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relacionamentos
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_services")
}

// Partnership model - Relacionamento empresa-fornecedor
model Partnership {
  id             String            @id @default(cuid())
  companyId      String
  supplierId     String
  status         PartnershipStatus @default(PENDING)
  startDate      DateTime?
  endDate        DateTime?
  renewalDate    DateTime?
  contractTerms  Json              @default("{}")
  paymentTerms   String?
  discount       Float             @default(0)
  minimumOrder   Float?
  isAutoRenewal  Boolean           @default(false)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdById    String

  // Relacionamentos
  company        Company           @relation("CompanyPartnerships", fields: [companyId], references: [id], onDelete: Cascade)
  supplier       Supplier          @relation("SupplierPartnerships", fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy      User              @relation(fields: [createdById], references: [id])
  reviews        SupplierReview[]  @relation("PartnershipReviews")

  @@unique([companyId, supplierId])
  @@map("partnerships")
}

// PartnershipRequest model - Solicitações de parceria
model PartnershipRequest {
  id             String                   @id @default(cuid())
  companyId      String
  supplierId     String
  requesterId    String
  status         PartnershipRequestStatus @default(PENDING)
  message        String?
  response       String?
  serviceIds     Json                     @default("[]")
  expectedVolume String?
  budget         Float?
  timeline       String?
  respondedAt    DateTime?
  respondedById  String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  // Relacionamentos
  company        Company                  @relation("CompanyPartnershipRequests", fields: [companyId], references: [id], onDelete: Cascade)
  supplier       Supplier                 @relation("SupplierPartnershipRequests", fields: [supplierId], references: [id], onDelete: Cascade)
  requester      User                     @relation(fields: [requesterId], references: [id])
  respondedBy    User?                    @relation("PartnershipRequestResponses", fields: [respondedById], references: [id])

  @@map("partnership_requests")
}

// SupplierReview model - Avaliações dos fornecedores
model SupplierReview {
  id           String      @id @default(cuid())
  supplierId   String
  companyId    String
  userId       String
  partnershipId String?
  rating       Int         // 1 a 5
  title        String?
  comment      String?
  aspects      Json        @default("{}") // {"quality": 5, "delivery": 4, "support": 5}
  isVerified   Boolean     @default(false)
  isAnonymous  Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relacionamentos
  supplier     Supplier    @relation("SupplierReviews", fields: [supplierId], references: [id], onDelete: Cascade)
  company      Company     @relation("CompanySupplierReviews", fields: [companyId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  partnership  Partnership? @relation("PartnershipReviews", fields: [partnershipId], references: [id])

  @@unique([supplierId, companyId])
  @@map("supplier_reviews")
}

// MarketplaceFavorite model - Favoritos das empresas
model MarketplaceFavorite {
  id         String   @id @default(cuid())
  companyId  String
  supplierId String
  userId     String
  createdAt  DateTime @default(now())

  // Relacionamentos
  company    Company  @relation("CompanyFavorites", fields: [companyId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation("SupplierFavorites", fields: [supplierId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, supplierId])
  @@map("marketplace_favorites")
}

// MarketplaceActivity model - Analytics do marketplace
model MarketplaceActivity {
  id         String   @id @default(cuid())
  type       String   // "view", "contact", "favorite", "request_partnership"
  userId     String
  companyId  String?
  supplierId String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  // Relacionamentos
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company?  @relation("CompanyActivities", fields: [companyId], references: [id])
  supplier   Supplier? @relation("SupplierActivities", fields: [supplierId], references: [id])

  @@map("marketplace_activities")
}

// =================== STRIPE CONNECT MODELS ===================

model StripeConnectTransaction {
  id                        String                        @id @default(cuid())
  stripeTransactionId       String                        @unique  // ID da transação no Stripe
  connectedAccountId        String                        // ID da conta conectada (supplier)
  platformStripeAccountId   String?                       // ID da conta da plataforma
  type                      StripeTransactionType
  status                    StripeTransactionStatus
  amount                    Int                           // Valor em centavos
  currency                  String                        @default("brl")
  platformCommission        Int                           // Comissão da plataforma em centavos
  supplierAmount            Int                           // Valor para o fornecedor em centavos
  description               String?
  metadata                  Json                          @default("{}")
  stripeCreatedAt           DateTime                      // Data da transação no Stripe
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  
  // Relacionamentos
  supplier                  Supplier                      @relation(fields: [connectedAccountId], references: [stripeConnectAccountId])
  transfers                 StripeConnectTransfer[]

  @@map("stripe_connect_transactions")
}

model StripeConnectTransfer {
  id                      String                        @id @default(cuid())
  stripeTransferId        String                        @unique   // ID da transferência no Stripe
  transactionId           String                        // Referência à transação
  connectedAccountId      String                        // Conta de destino
  amount                  Int                           // Valor transferido em centavos
  currency                String                        @default("brl")
  status                  StripeTransferStatus
  description             String?
  stripeCreatedAt         DateTime                      // Data da transferência no Stripe
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt
  
  // Relacionamentos
  transaction             StripeConnectTransaction      @relation(fields: [transactionId], references: [id])
  supplier                Supplier                      @relation(fields: [connectedAccountId], references: [stripeConnectAccountId])

  @@map("stripe_connect_transfers")
}

// Enums para Stripe Connect
enum StripeTransactionType {
  PAYMENT           // Pagamento recebido
  REFUND           // Reembolso
  ADJUSTMENT       // Ajuste
  PAYOUT           // Pagamento para conta bancária
}

enum StripeTransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum StripeTransferStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  IN_TRANSIT
}

// Subscription Plan Enums
enum SupplierPlanType {
  STARTER       // R$ 49/mês
  GROWTH        // R$ 149/mês  
  PROFESSIONAL  // R$ 299/mês
  ENTERPRISE    // R$ 999/mês
}

enum SupplierSubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

// Supplier Subscription Plans
model SupplierSubscriptionPlan {
  id                    String              @id @default(cuid())
  planType              SupplierPlanType
  name                  String              
  description           String?
  monthlyPrice          Int                 // Preço em centavos
  stripeProductId       String              @unique
  stripePriceId         String              @unique
  
  // Limites do plano
  maxProducts           Int?                // null = ilimitado
  maxPartnerships       Int?                // null = ilimitado
  commissionRate        Float               // Taxa de comissão (0.05 = 5%)
  
  // Recursos incluídos
  prioritySupport       Boolean             @default(false)
  advancedAnalytics     Boolean             @default(false)
  apiAccess             Boolean             @default(false)
  whiteLabel            Boolean             @default(false)
  dedicatedManager      Boolean             @default(false)
  customReports         Boolean             @default(false)
  slaGuarantee          Boolean             @default(false)
  
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  // Relacionamentos
  subscriptions         SupplierSubscription[]

  @@map("supplier_subscription_plans")
}

// Active subscriptions for suppliers
model SupplierSubscription {
  id                    String                      @id @default(cuid())
  supplierId            String                      @unique
  planId                String
  stripeSubscriptionId  String                      @unique
  status                SupplierSubscriptionStatus
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean                     @default(false)
  canceledAt            DateTime?
  trialEnd              DateTime?
  
  // Usage tracking
  currentProductCount   Int                         @default(0)
  currentPartnershipCount Int                       @default(0)
  
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  
  // Relacionamentos
  supplier              Supplier                    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  plan                  SupplierSubscriptionPlan    @relation(fields: [planId], references: [id])

  @@map("supplier_subscriptions")
}
